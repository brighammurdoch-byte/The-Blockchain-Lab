# Blockchain Lab Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Session Management
SESSION_TTL=86400000
# Time in milliseconds before sessions auto-expire (default: 24 hours = 86400000 ms)
# Configure based on your class duration. Examples:
# - For a 2-hour class: 7200000
# - For a 4-hour class: 14400000
# - For a full day: 86400000

SESSION_CLEANUP_INTERVAL=1800000
# How often to check for expired sessions (default: 30 minutes = 1800000 ms)

# Blockchain Difficulty Settings
DIFFICULTY_LEADING_ZEROS=4
# Number of leading zeros required in block hash (higher = harder to mine)
# Examples: 2 = very easy (mine in seconds), 3 = easy (mine in 10-30 secs), 4 = moderate

DIFFICULTY_SECONDARY=8
# Secondary difficulty hex value (0-15)
# Used with leading zeros to fine-tune mining difficulty

MINING_REWARD=10
# Number of coins awarded for successfully mining a block

BLOCK_TIME_TARGET=30000
# Target block time in milliseconds (informational, used for difficulty adjustment algorithms)
# Default: 30 seconds = 30000 ms

# Proof of Work Settings
MAX_MINING_ITERATIONS=1000000
# Maximum number of hash attempts per mining attempt
# Lower values = faster mining but less secure
# Higher values = slower mining but more secure

# Cryptocurrency Settings
INITIAL_WALLET_BALANCE=100
# Starting balance (in coins) for each participant when they join a session

# Optional: API Keys (if using external services in future)
# API_KEY=your_key_here

# Optional: Database Configuration (if persistence added later)
# DATABASE_URL=connectionstring
# DB_NAME=blockchain_lab
